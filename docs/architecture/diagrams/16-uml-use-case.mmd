    UCAssist(["局部 AI 辅助"])
    UCConfirm(["确认 AI 草案并落库"])
    UCTodo(["管理今日清单"])
    UCEnergy(["记录每日能量"])
    UCPlan(["查看与调整计划"])
    UCSettlement(["确认周结算"])
    UCTree(["查看年度成长树"])
